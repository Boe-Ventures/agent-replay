{
  "name": "@boe-ventures/agent-replay",
  "version": "0.2.1",
  "description": "Local session recording for AI coding agents — captures DOM mutations, console logs, network requests, and errors from your dev server into structured JSONL files that agents can read directly",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agent-replay": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "default": "./dist/react/index.js"
    },
    "./next": {
      "types": "./dist/next/index.d.ts",
      "import": "./dist/next/index.js",
      "default": "./dist/next/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js",
      "default": "./dist/cli/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "prepublishOnly": "pnpm typecheck && pnpm build"
  },
  "keywords": [
    "session-recording",
    "rrweb",
    "ai-agent",
    "developer-tools",
    "debugging",
    "console-log",
    "network-capture",
    "react",
    "nextjs",
    "local-development",
    "devtools"
  ],
  "homepage": "https://boe-ventures.github.io/agent-replay",
  "repository": {
    "type": "git",
    "url": "https://github.com/Boe-Ventures/agent-replay.git"
  },
  "bugs": {
    "url": "https://github.com/Boe-Ventures/agent-replay/issues"
  },
  "author": "Boe Ventures <hello@boe.ventures> (https://github.com/Boe-Ventures)",
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@rrweb/rrweb-plugin-console-record": "^2.0.0-alpha.20",
    "@rrweb/types": "^2.0.0-alpha.20",
    "rrweb": "^2.0.0-alpha.4",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "next": {
      "optional": true
    }
  }
}
